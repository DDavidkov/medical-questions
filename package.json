{
  "name": "medical-questions-demo",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate:up": "node-pg-migrate up --database-url-var DATABASE_URL --migrations-dir migrations --migration-file-language sql",
    "migrate:down": "node-pg-migrate down --database-url-var DATABASE_URL --migrations-dir migrations --migration-file-language sql",
    "ingest": "tsx src/ingestion/ingest.ts"
  },
