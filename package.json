  "description": "",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "fastify": "^5.8.2",
    "node-pg-migrate": "^8.0.4",
    "openai": "^6.31.0",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
